# --- Setări Discord ---
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/ID/TOKEN

# --- Setări Telegram ---
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_CHAT_ID=123456789

# --- Setări Detectie ---
# Câte conexiuni simultane să aibă un IP înainte de a fi considerat atac
CONNECTION_THRESHOLD=100
# La câte conexiuni să apară în live feed (pentru a nu spam consola)
LIVE_FEED_THRESHOLD=15
# Intervalul de verificare în secunde
CHECK_INTERVAL=2

# --- Setări Securitate ---
# IP-uri care NU vor fi blocate niciodată (separate prin virgulă)
# Adaugă aici IP-ul serverului tău sau IP-uri de admin
WHITELIST_IPS=127.0.0.1,8.8.8.8