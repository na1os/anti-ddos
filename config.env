# --- Setări Discord & Telegram ---
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Setări Detectie ---
CONNECTION_THRESHOLD=100
LIVE_FEED_THRESHOLD=15
CHECK_INTERVAL=2

# --- NOU: Securitate Avansată ---
# Cât timp să rămână blocat IP-ul (în secunde). 3600 = 1 oră.
BAN_DURATION=3600
# Portele monitorizate (separate prin virgulă). Lasă gol pentru a monitoriza TOT.
MONITOR_PORTS=80,443,22

# IP-uri permise (nu se blochează niciodată)
WHITELIST_IPS=127.0.0.1,8.8.8.8